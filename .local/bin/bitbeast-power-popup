#!/usr/bin/env python3

import os
import re
import shutil
import signal
import subprocess
import sys
from datetime import datetime

import gi

gi.require_version("Gtk", "3.0")
gi.require_version("GtkLayerShell", "0.1")

from gi.repository import Gdk, GLib, Gtk, GtkLayerShell

PID_DIR = os.path.expanduser("~/.cache/bitbeast")
PID_FILE = os.path.join(PID_DIR, "power-popup.pid")
BG = "#11141d"
TEXT = "#f5f7ff"
TEXT_DIM = "rgba(245,247,255,0.66)"
PRIMARY = "#ff4d67"
PRIMARY_ALT = "#ff3658"
ACCENT = "#ff7b8e"


def cmd(args):
    try:
        return subprocess.check_output(args, stderr=subprocess.DEVNULL).decode().strip()
    except Exception:
        return ""


def run(args):
    try:
        subprocess.Popen(args, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL)
    except Exception:
        pass


def toggle_existing_instance() -> bool:
    os.makedirs(PID_DIR, exist_ok=True)

    if not os.path.exists(PID_FILE):
        return False

    try:
        with open(PID_FILE, "r", encoding="utf-8") as handle:
            old_pid = int(handle.read().strip())
    except Exception:
        return False

    if old_pid <= 0:
        return False

    try:
        os.kill(old_pid, signal.SIGTERM)
        return True
    except ProcessLookupError:
        return False
    except Exception:
        return False


def write_pid_file():
    os.makedirs(PID_DIR, exist_ok=True)
    with open(PID_FILE, "w", encoding="utf-8") as handle:
        handle.write(str(os.getpid()))


def remove_pid_file():
    try:
        if os.path.exists(PID_FILE):
            os.remove(PID_FILE)
    except OSError:
        pass


def get_player():
    players = cmd(["playerctl", "-l"])
    if not players:
        return None
    for player in players.splitlines():
        lowered = player.lower()
        if any(name in lowered for name in ("spotify", "google-chrome-stable", "chromium", "mpv", "vlc", "rhythmbox", "cmus")):
            return player
    return players.splitlines()[0]


def fmt_time(seconds):
    try:
        seconds = int(float(seconds))
    except Exception:
        return "0:00"
    return f"{seconds // 60}:{seconds % 60:02d}"


def get_volume_percent():
    output = cmd(["pactl", "get-sink-volume", "@DEFAULT_SINK@"]) or ""
    match = re.search(r"(\d+)%", output)
    return int(match.group(1)) if match else 0


def set_volume_percent(value):
    subprocess.run(["pactl", "set-sink-volume", "@DEFAULT_SINK@", f"{int(value)}%"], stderr=subprocess.DEVNULL)


def get_volume_muted():
    output = cmd(["pactl", "get-sink-mute", "@DEFAULT_SINK@"]) or ""
    return output.endswith("yes")


def get_brightness_percent():
    output = cmd(["brightnessctl", "-m"])
    if not output:
        return 0
    parts = output.split(",")
    if len(parts) < 4:
        return 0
    try:
        return int(parts[3].rstrip("%"))
    except Exception:
        return 0


def set_brightness_percent(value):
    subprocess.run(["brightnessctl", "set", f"{int(value)}%"], stderr=subprocess.DEVNULL)


def wifi_enabled():
    return cmd(["nmcli", "radio", "wifi"]).strip().lower() == "enabled"


def toggle_wifi():
    run(["nmcli", "radio", "wifi", "off" if wifi_enabled() else "on"])


def bluetooth_enabled():
    return "Powered: yes" in cmd(["bluetoothctl", "show"])


def toggle_bluetooth():
    run(["bluetoothctl", "power", "off" if bluetooth_enabled() else "on"])


def airplane_enabled():
    radios = cmd(["nmcli", "radio", "all"]).lower()
    return "disabled" in radios and "enabled" not in radios


def toggle_airplane():
    if airplane_enabled():
        run(["nmcli", "radio", "all", "on"])
        run(["bluetoothctl", "power", "on"])
    else:
        run(["nmcli", "radio", "all", "off"])
        run(["bluetoothctl", "power", "off"])


def notifications_count():
    output = cmd(["swaync-client", "-c"])
    try:
        return int(output)
    except Exception:
        return 0


def notification_summary():
    count = notifications_count()
    return "No new notifications" if count == 0 else f"{count} pending notifications"


def sink_name():
    sink = cmd(["pactl", "get-default-sink"])
    if sink:
        return sink.rsplit(".", 1)[-1].replace("_", " ").title()
    info = cmd(["pactl", "info"])
    match = re.search(r"Default Sink:\s*(.+)", info)
    if not match:
        return "Default Output"
    return match.group(1).rsplit(".", 1)[-1].replace("_", " ").title()


def cpu_usage_percent(previous):
    line = ""
    try:
        with open("/proc/stat", "r", encoding="utf-8") as handle:
            line = handle.readline()
    except Exception:
        return 0.0, previous

    fields = [int(value) for value in line.split()[1:]]
    idle = fields[3] + fields[4]
    total = sum(fields)

    if previous is None:
        return 0.0, (idle, total)

    prev_idle, prev_total = previous
    delta_idle = idle - prev_idle
    delta_total = total - prev_total
    if delta_total <= 0:
        return 0.0, (idle, total)
    usage = 100.0 * (1.0 - (delta_idle / delta_total))
    return max(0.0, min(usage, 100.0)), (idle, total)


def ram_usage_percent():
    values = {}
    try:
        with open("/proc/meminfo", "r", encoding="utf-8") as handle:
            for line in handle:
                key, raw = line.split(":", 1)
                values[key] = int(raw.strip().split()[0])
    except Exception:
        return 0
    total = values.get("MemTotal", 1)
    available = values.get("MemAvailable", 0)
    return int(((total - available) / total) * 100)


def disk_usage_percent():
    usage = shutil.disk_usage("/")
    return int((usage.used / usage.total) * 100)


