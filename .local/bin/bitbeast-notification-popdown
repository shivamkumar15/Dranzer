#!/bin/bash
# BitBeast Notification Popdown - Shows notifications in a dropdown

NOTIF_DIR="$HOME/.cache/swaync"
STATE_FILE="$NOTIF_DIR/state.json"
CONFIG_DIR="$HOME/.config/swaync"

get_config() {
    local key=$1
    local default=$2
    if [ -f "$CONFIG_DIR/config.json" ]; then
        grep "\"$key\"" "$CONFIG_DIR/config.json" | sed 's/.*"\('$key'\)": *"\?\([^"]*\)"\?.*/\2/' | head -1
    fi
    [ -n "$default" ] && echo "$default"
}

clear_notifications() {
    if command -v swaync-client >/dev/null 2>&1; then
        swaync-client -C -r
    fi
}

show_notification_popdown() {
    if ! command -v swaync-client >/dev/null 2>&1; then
        echo "swaync not installed"
        exit 1
    fi
    
    swaync-client -pp
}

toggle_dnd() {
    if command -v swaync-client >/dev/null 2>&1; then
        swaync-client -t -sw
    fi
}

toggle_persistence() {
    if command -v swaync-client >/dev/null 2>&1; then
        swaync-client -m -sw
    fi
}

case "${1:-}" in
    clear)
        clear_notifications
        ;;
    popdown|show)
        show_notification_popdown
        ;;
    dnd)
        toggle_dnd
        ;;
    persistent|persistence)
        toggle_persistence
        ;;
    *)
        show_notification_popdown
        ;;
esac