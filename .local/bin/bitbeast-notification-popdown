#!/bin/bash
# BitBeast Notification Popdown — Controls the SwayNC panel

case "${1:-toggle}" in
    popdown|show|toggle)
        swaync-client -t -sw
        ;;
    open)
        swaync-client -op
        ;;
    close)
        swaync-client -cp
        ;;
    clear)
        swaync-client -C
        ;;
    dnd)
        swaync-client -d -sw
        ;;
    count)
        swaync-client -c
        ;;
    *)
        swaync-client -t -sw
        ;;
esac