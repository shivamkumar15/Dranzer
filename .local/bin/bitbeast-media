#!/bin/bash
# BitBeast Media - Modern music player control with album art

CACHE_DIR="$HOME/.cache/bitbeast"
mkdir -p "$CACHE_DIR"

get_player() {
    playerctl -l 2>/dev/null | grep -E "spotify|firefox|chromium|mpv|vlc|audacious|rhythmbox" | head -1
}

get_album_art() {
    local player=$1
    local url=$(playerctl -p "$player" metadata mpris:artUrl 2>/dev/null)
    
    if [ -z "$url" ]; then
        echo ""
        return
    fi
    
    if [[ "$url" == file://* ]]; then
        echo "${url#file://}"
        return
    fi
    
    if [[ "$url" == http://* ]] || [[ "$url" == https://* ]]; then
        local cached="$CACHE_DIR/$(echo "$url" | md5sum | cut -d' ' -f1).jpg"
        
        if [ ! -f "$cached" ]; then
            curl -sL "$url" -o "$cached" 2>/dev/null
        fi
        
        if [ -f "$cached" ]; then
            echo "$cached"
        fi
    fi
}

get_status() {
    playerctl status 2>/dev/null
}

get_title() {
    playerctl -p "$PLAYER" metadata title 2>/dev/null | cut -c1-40
}

get_artist() {
    playerctl -p "$PLAYER" metadata artist 2>/dev/null | cut -c1-30
}

get_position() {
    playerctl position 2>/dev/null | cut -d. -f1
}

get_duration() {
    playerctl -p "$PLAYER" metadata mpris:length 2>/dev/null | cut -d. -f1 | awk '{printf "%d", $1/1000000}'
}

format_time() {
    local secs=$1
    printf "%d:%02d" $((secs/60)) $((secs%60))
}

PLAYER=$(get_player)

if [ -z "$PLAYER" ]; then
    echo '{"text": "¾░Øī ", "class": "stopped", "tooltip": "No media playing"}'
    exit 0
fi

STATUS=$(get_status)
TITLE=$(get_title)
ARTIST=$(get_artist)
POSITION=$(get_position)
DURATION=$(get_duration)

if [ -z "$TITLE" ]; then
    TITLE=$(playerctl -p "$PLAYER" metadata xesam:url 2>/dev/null | xargs basename 2>/dev/null | cut -c1-40)
fi

if [ -z "$TITLE" ]; then
    echo '{"text": "¾░Øī ", "class": "stopped", "tooltip": "No media playing"}'
    exit 0
fi

ALBUM_ART=$(get_album_art "$PLAYER")

CASE="playing"
if [ "$STATUS" = "Playing" ]; then
    CASE="playing"
    ICON="¾░╣ó"
elif [ "$STATUS" = "Paused" ]; then
    CASE="paused"
    ICON="¾░ÉŖ"
else
    CASE="stopped"
    ICON="¾░Øī "
fi

TOOLTIP="$TITLE by $ARTIST\nPosition: $(format_time $POSITION)/$(format_time $DURATION)"

# Build valid single-line JSON
if [ -n "$ALBUM_ART" ] && [ -f "$ALBUM_ART" ]; then
    printf '{"text": "%s %s", "class": "%s", "alt": "%s", "tooltip": "%s", "image-path": "%s"}\n' \
        "$ICON" "$TITLE" "$CASE" "$ICON" "$TOOLTIP" "$ALBUM_ART"
else
    printf '{"text": "%s %s", "class": "%s", "alt": "%s", "tooltip": "%s"}\n' \
        "$ICON" "$TITLE" "$CASE" "$ICON" "$TOOLTIP"
fi