#!/bin/bash

# BitBeast Workspace Overview Script
# Uses Rofi to show active windows with thumbnails in a grid layout

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
ROFI_THEME="$CONFIG_HOME/rofi/overview.rasi"

# Launch Rofi window switcher with thumbnails
rofi -show window -window-thumbnail -theme "$ROFI_THEME"
