@import "./bitbeast.css";
@import "./bitbeast-style.css";

* {
    border: none;
    border-radius: 0;
    font-family: "JetBrainsMono Nerd Font", "Font Awesome 6 Free", monospace;
    font-size: 15px;
    font-weight: 700;
    min-height: 0;
    transition-property: background-color, border-color, color, box-shadow, opacity;
    transition-duration: 180ms;
    transition-timing-function: cubic-bezier(0.22, 1, 0.36, 1);
}

window#waybar {
    background: transparent;
    color: @text;
}

window#waybar.hidden {
    opacity: 0.35;
}

@keyframes island-shimmer {
    0% {
        background-position: 0% 50%;
        box-shadow: 0 16px 30px alpha(@bg, 0.28), inset 0 1px 0 alpha(white, 0.05), 0 0 12px alpha(@glow, 0.1);
    }
    50% {
        background-position: 100% 50%;
        box-shadow: 0 18px 34px alpha(@bg, 0.34), inset 0 1px 0 alpha(white, 0.08), 0 0 18px alpha(@glow, 0.18);
    }
    100% {
        background-position: 0% 50%;
        box-shadow: 0 16px 30px alpha(@bg, 0.28), inset 0 1px 0 alpha(white, 0.05), 0 0 12px alpha(@glow, 0.1);
    }
}

@keyframes media-pulse {
    0% {
        color: @text;
        text-shadow: 0 0 8px alpha(@primary, 0.25);
    }
    100% {
        color: @primary;
        text-shadow: 0 0 14px alpha(@glow, 0.45);
    }
}

@keyframes critical-pulse {
    from {
        background: alpha(#ff5d73, 0.18);
        box-shadow: 0 0 0 alpha(#ff5d73, 0);
    }
    to {
        background: alpha(#ff5d73, 0.28);
        box-shadow: 0 0 16px alpha(#ff5d73, 0.35);
    }
}

.modules-left,
.modules-center,
.modules-right {
    background: linear-gradient(120deg, alpha(@bg, 0.9), alpha(@bg-alt, 0.74) 52%, alpha(@bg, 0.92));
    background-size: 200% 200%;
    animation: island-shimmer 12s ease infinite;
    border-top: 1px solid alpha(@glow, 0.55);
    border-bottom: 1px solid alpha(@accent, 0.16);
    border-left: 1px solid alpha(white, 0.06);
    border-right: 1px solid alpha(white, 0.06);
    border-radius: 22px;
    margin: 4px 6px;
    padding: 3px 8px;
    box-shadow: 0 18px 36px alpha(@bg, 0.34), inset 0 1px 0 alpha(white, 0.06), 0 0 18px alpha(@glow, 0.12);
}

.modules-left:hover,
.modules-center:hover,
.modules-right:hover {
    border-top-color: alpha(@glow, 0.8);
    box-shadow: 0 20px 40px alpha(@bg, 0.38), inset 0 1px 0 alpha(white, 0.08), 0 0 24px alpha(@glow, 0.2);
}

.modules-center {
    min-width: 280px;
}

tooltip,
menu {
    background: alpha(@bg, 0.96);
    border: 1px solid alpha(@glow, 0.28);
    border-radius: 14px;
    box-shadow: 0 14px 30px alpha(@bg, 0.36), 0 0 14px alpha(@glow, 0.16);
    color: @text;
}

tooltip label {
    padding: 8px 14px;
    font-weight: 700;
}

menu {
    padding: 8px;
}

menuitem {
    border-radius: 10px;
    padding: 6px 10px;
}

menuitem:hover {
    background: alpha(@glow, 0.14);
    color: @glow;
}

#custom-theme,
#workspaces,
#window,
#custom-media,
#clock,
#cava,
#cpu,
#memory,
#pulseaudio,
#network,
#battery,
#backlight,
#custom-lock,
#tray,
#custom-sysicon,
#custom-notification,
#custom-batterybar {
    margin: 3px;
    padding: 4px 12px;
    border-radius: 16px;
    color: @text;
}

#group-audio,
#group-system {
    margin: 3px;
    padding: 0;
    background: transparent;
}

#custom-theme {
    padding-left: 14px;
    padding-right: 14px;
    color: @glow;
    font-weight: 900;
    background: linear-gradient(180deg, alpha(@glow, 0.16), alpha(@secondary, 0.08));
    box-shadow: inset 0 0 0 1px alpha(@glow, 0.18);
    text-shadow: 0 0 10px alpha(@glow, 0.35);
}

#custom-theme:hover,
#custom-notification:hover,
#custom-lock:hover,
#clock:hover,
#custom-sysicon:hover {
    background: alpha(@glow, 0.16);
    color: @glow;
    text-shadow: 0 0 12px alpha(@glow, 0.5);
}

#workspaces {
    padding-left: 8px;
    padding-right: 8px;
    background: alpha(@bg-alt, 0.24);
}

#workspaces button {
    min-width: 18px;
    padding: 2px 6px;
    margin: 2px 3px;
    border-radius: 10px;
    background: transparent;
    color: alpha(@text, 0.38);
}

#workspaces button:hover {
    background: alpha(@glow, 0.14);
    color: @glow;
}

#workspaces button.active {
    min-width: 28px;
    background: linear-gradient(180deg, alpha(@accent, 0.92), alpha(@primary, 0.92));
    color: @bg;
    box-shadow: 0 0 12px alpha(@glow, 0.25);
}

#workspaces button.urgent {
    background: alpha(#ff5d73, 0.22);
    color: white;
}

#window {
    min-width: 180px;
    padding-left: 14px;
    padding-right: 14px;
    color: alpha(@text, 0.88);
    background: linear-gradient(90deg, alpha(@bg-alt, 0.34), alpha(@bg-alt, 0.12));
}

#custom-media {
    min-width: 260px;
    padding-left: 16px;
    padding-right: 16px;
    background: linear-gradient(90deg, alpha(@primary, 0.16), alpha(@secondary, 0.12));
    border: 1px solid alpha(@glow, 0.18);
    box-shadow: 0 10px 24px alpha(@primary, 0.12);
}

#custom-media.playing {
    animation: media-pulse 2s ease-in-out infinite alternate;
}

#custom-media.paused {
    color: alpha(@text, 0.62);
    background: alpha(@bg-alt, 0.28);
    border-color: alpha(@text, 0.08);
    box-shadow: none;
}

#custom-media.stopped {
    opacity: 0.55;
    box-shadow: none;
}

#clock {
    font-size: 16px;
    font-weight: 800;
    background: linear-gradient(180deg, alpha(@glow, 0.1), alpha(@secondary, 0.08));
    border: 1px solid alpha(@glow, 0.18);
}

#cava {
    min-width: 52px;
    color: @primary;
    letter-spacing: 2px;
    background: alpha(@bg-alt, 0.24);
    text-shadow: 0 0 8px alpha(@glow, 0.24);
}

#custom-batterybar {
    color: @accent;
    letter-spacing: 0.12em;
    background: alpha(@accent, 0.08);
}

#custom-notification {
    color: @primary;
    background: alpha(@primary, 0.12);
}

#custom-sysicon {
    padding-left: 12px;
    padding-right: 12px;
    font-size: 18px;
    color: @glow;
    background: alpha(@glow, 0.09);
}

#cpu {
    color: #ff8b94;
    background: alpha(#ff8b94, 0.1);
}

#memory {
    color: #ffaaa5;
    background: alpha(#ffaaa5, 0.1);
}

#network {
    color: #88d8b0;
    background: alpha(#88d8b0, 0.1);
}

#network.disconnected {
    color: #ff8b94;
    background: alpha(#ff8b94, 0.12);
}

#pulseaudio {
    color: @accent;
    background: alpha(@accent, 0.12);
}

#pulseaudio.muted {
    color: alpha(@text, 0.55);
    background: alpha(@text, 0.06);
}

#backlight {
    color: #ffe066;
    background: alpha(#ffe066, 0.1);
}

#battery {
    color: #ffcc5c;
    background: alpha(#ffcc5c, 0.12);
}

#battery.charging,
#battery.plugged {
    color: #88d8b0;
    background: alpha(#88d8b0, 0.15);
    text-shadow: 0 0 8px alpha(#88d8b0, 0.35);
}

#battery.warning:not(.charging) {
    background: alpha(#ffd166, 0.18);
}

#battery.critical:not(.charging) {
    color: #ff5d73;
    background: alpha(#ff5d73, 0.2);
    animation: critical-pulse 1s infinite alternate;
}

.audio-drawer,
.system-drawer {
    background: transparent;
}

#tray {
    padding-left: 10px;
    padding-right: 10px;
    background: alpha(@bg-alt, 0.24);
}

#tray > .passive {
    -gtk-icon-effect: dim;
}

#tray > .needs-attention {
    background: alpha(@glow, 0.14);
    border-radius: 12px;
}

#custom-lock {
    color: alpha(@text, 0.55);
}
