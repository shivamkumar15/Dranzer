{
  "exclusive": true,
  "reload_style_on_change": true,
  "position": "top",
  "spacing": 0,
  "height": 24,
  "width": 1440,
  "modules-left": [
    "group/left1"
  ],
  "modules-center": [
    "clock",
    "custom/idle-indicator",
    "custom/notification-silencing-indicator",
    "custom/voxtype",
    "custom/weather",
    "custom/screenrecording-indicator"

  ],
  "modules-right": [
    "group/right2",
    "group/right1",
    "group/right3"
  ],
  
  "group/left1": {
    "orientation": "inherit",
    "modules": [
    "custom/omarchy",
    "custom/omarchy-theme-set",
    "hyprland/workspaces"
  ]
  },
    "group/right3": {
    "orientation": "inherit",
    "modules": [
    "idle_inhibitor",
    "custom/updatespacman",
    "custom/update",
    "bluetooth",
    "backlight",
    "network",
    "power-profiles-daemon",
    "pulseaudio#output",
    "pulseaudio#input",
    "memory",
    "cpu",
    "battery"
  ]
  },
    "group/right2": {
    "orientation": "inherit",
    "modules": ["mpris"]
  },
    "group/right1": {
    "orientation": "inherit",
    "modules": ["tray"]
  },
  
  "custom/omarchy-theme-set": {
  "on-click": "omarchy-theme-set Harbordark",
  "tooltip-format": "Back to your setted Theme",
  "interval": 5,
  "format": "у°”Һ"
},

  "hyprland/workspaces": {
  "persistent-workspaces": {"*": [ 1,2,3,4,5,6 ]},
	"on-click": "activate",
	"format": "{windows}",
	"format-window-separator": " ",
	"window-rewrite-default": "пҒҷ",
	"window-rewrite": {		"custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "у°Қ¬",
      "transcribing": "у°”ҹ"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },
        "class<.*imv*.>": "п“Ҙ",
        "class<.*bambustudio*.>": "у°җ«",
        "class<.*bitwarden*.>": "оҙҘ",
        "class<.*handbrake*.>": "у°Ҳ«",
        "class<.*stremio*.>": "уұ–Ҹ",
        "title<.*waydroid*.>": "оңҺ",
        "class<.*grayjay*.>": "уұ—Ҷ",
		"title<.*amazon.*>": "пү°",
		"class<google-chrome-stable|org.mozilla.google-chrome-stable|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "оқ…",
		"class<zen>": "у°°·",
